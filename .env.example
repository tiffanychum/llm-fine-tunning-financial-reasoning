# Copy this to .env and fill in your keys
# Never commit .env to git

POE_API_KEY=your_poe_api_key_here         # poe.com/api_key
WANDB_API_KEY=your_wandb_api_key_here     # wandb.ai/authorize
HF_TOKEN=your_huggingface_token_here      # huggingface.co/settings/tokens
OPENROUTER_API_KEY=your_openrouter_key    # openrouter.ai/keys  ← TRUE Qwen2.5-7B baseline
